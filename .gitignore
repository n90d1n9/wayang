
# --------------------
# Quarkus / Maven Multi-Module Specific
# --------------------

# Maven Build Output (applies to all modules, including root target)
# The `target` directory in the root and all submodules.
target/
**/target/

build/
**/build/

.venv
**/.venv/

.gradle-sandbox/
.gradle-worker/

# The generated Quarkus application runner JAR structure (inside target/)
# This ensures that the final packaged application (which includes lib/) is ignored.
quarkus-app/

# Quarkus native executable artifacts generated at the repository root.
/*-runner
/*-runner.exe
/*-runner.native
/*-runner.build-artifacts.zip

# Source modules whose names overlap with generated native runner artifacts
# or broad local excludes.
!/core/gollek-model-runner/
!/core/gollek-model-runner/**
!/runtime/
!/runtime/gollek-runtime/
!/runtime/gollek-runtime/build.gradle.kts
!/runtime/gollek-runtime-distributed/
!/runtime/gollek-runtime-distributed/build.gradle.kts
/core/gollek-model-runner/build/
/runtime/gollek-runtime/build/
/runtime/gollek-runtime-distributed/build/
/runtime/gollek-runtime/src/
/runtime/gollek-runtime-distributed/src/

# Native Image specific build files
**/*.graal.log
**/*.build.log
**/*.o
**/*.d
**/*.gc.log

# Maven Wrapper files (usually checked in, but sometimes people exclude the whole .mvn)
# If you check in the wrapper scripts (mvnw, mvnw.cmd), keep these commented out.
# .mvn/wrapper/maven-wrapper.jar

# Log files generated during development or testing
*.log
log/
tmp/
logs/

