# Minimal module selection manifest for local dev
# Populated by build/run scripts when an explicit selection manifest is missing.
BACKEND_TARGETS="native-java"
FORMAT_TARGETS="gguf"
LLM_TARGETS="gemma-4,gemma-3"
RESOLVED_BACKEND_PROPERTY="native"
BUILD_PROFILE="dev"
GOLLEK_BIN_DIR="${HOME}/.local/bin"
ARCHITECTURE_TARGETS="native-java"
ARCHITECTURE_TARGET="native-java"
MODULES=":ui:wayang-cli :cli:wayang-gollek-cli"
# Optional flags
GOLLEK_PUBLISH_RUNTIME_LOCAL="false"
