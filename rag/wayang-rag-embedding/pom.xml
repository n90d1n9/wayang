<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>tech.kayys.wayang</groupId>
        <artifactId>wayang-rag-parent</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <groupId>tech.kayys.wayang</groupId>
    <artifactId>wayang-rag-embedding</artifactId>
    <version>1.0.0-SNAPSHOT</version>

    <properties>
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>${quarkus.platform.group-id}</groupId>
                <artifactId>${quarkus.platform.artifact-id}</artifactId>
                <version>${quarkus.platform.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <!-- Internal: RAG Core (RagChunk, VectorStore, etc.) -->
        <dependency>
            <groupId>tech.kayys.wayang</groupId>
            <artifactId>rag-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Internal: RAG Runtime (RagRuntimeConfig, etc.) -->
        <dependency>
            <groupId>tech.kayys.wayang</groupId>
            <artifactId>wayang-rag-runtime</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Internal: Embedding SPI (EmbeddingService, EmbeddingModuleConfig, etc.) -->
        <dependency>
            <groupId>tech.kayys.wayang</groupId>
            <artifactId>wayang-embedding-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Quarkus CDI/IoC -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-arc</artifactId>
        </dependency>

        <!-- Quarkus REST -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-rest-jackson</artifactId>
        </dependency>

        <!-- Quarkus Scheduler (for history compactor job) -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-scheduler</artifactId>
        </dependency>

        <!-- Quarkus Micrometer (for MeterRegistry) -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-micrometer</artifactId>
        </dependency>

        <!-- MicroProfile Config (for @ConfigProperty) -->
        <dependency>
            <groupId>org.eclipse.microprofile.config</groupId>
            <artifactId>microprofile-config-api</artifactId>
        </dependency>

        <!-- SLF4J Logger -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>

        <!-- Test: JUnit 5 -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-junit</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Test: Mockito -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-junit-mockito</artifactId>
            <scope>test</scope>
        </dependency>

    </dependencies>

</project>