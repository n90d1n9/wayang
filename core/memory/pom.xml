<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>tech.kayys.wayang</groupId>
        <artifactId>wayang-agentic-parent</artifactId>
        <version>1.0.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>
    <groupId>tech.kayys.wayang</groupId>
    <artifactId>wayang-memory-parent</artifactId>
    <packaging>pom</packaging>
    <modules>
        <module>memory-core</module>
        <module>golek-memory-context-engineering</module>
        <module>golek-memory-short</module>
        <module>golek-memory-working</module>
        <module>golek-memory-episodic</module>
        <module>golek-memory-semantic</module>
        <module>golek-memory-longterm</module>
        <module>gollek-plugin-memory-integration</module>
        <module>vector-memory-integration</module>
        <module>graph-memory-integration</module>
        <module>memory-runtime</module>
        <!--
            All memory modules are now inside the active memory parent. Legacy
            Gollek-specific sources remain parked under module-local legacy
            source trees until their runtime contracts are mapped back through
            active Wayang memory, agent, and plugin SPIs.
        -->
    </modules>

    <properties>
        <quarkus.platform.version>3.32.2</quarkus.platform.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>io.quarkus.platform</groupId>
                <artifactId>quarkus-bom</artifactId>
                <version>${quarkus.platform.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>


    <dependencies>
        <!-- Validation -->
        <dependency>
            <groupId>jakarta.validation</groupId>
            <artifactId>jakarta.validation-api</artifactId>
        </dependency>

    </dependencies>
</project>
