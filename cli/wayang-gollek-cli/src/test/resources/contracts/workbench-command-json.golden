{"product":"Wayang","status":{"product":"Wayang","version":"1.0.0-SNAPSHOT","components":[{"name":"Gollek","role":"Inference, serving, and training engine","state":"external","endpoint":"configured by backend adapter","healthPercent":80},{"name":"Gamelan","role":"Workflow execution engine","state":"external","endpoint":"configured by workflow backend","healthPercent":80},{"name":"Agent Core","role":"Agentic orchestration and skills","state":"local","endpoint":"agent-spi + agent-core","healthPercent":90},{"name":"RAG Runtime","role":"Retrieval, plugins, and response assembly","state":"local","endpoint":"rag-runtime","healthPercent":90},{"name":"MCP","role":"Dynamic tool bridge","state":"adapter-ready","endpoint":"agent-mcp + wayang-tool-mcp","healthPercent":70}],"activeSkills":12,"notes":["Wayang SDK is the shared source of truth for agent product surfaces.","Wayang CLI is product-owned and separate from Gollek CLI.","Tamboui is used as a renderer reference, not the platform contract.","The CLI target is an agent workbench for coding, assistant, and workflow products.","Next SDK adapters should wire local runtime, remote API, and packaged agents."]},"catalog":{"product":"Wayang","coreEngine":"agents, skills, tools, MCP, RAG, memory, workflows, and harness checks","surfaces":[{"id":"coding-agent","name":"Coding Agent","role":"Workspace-aware terminal agent in the style of Gemini CLI or Claude Code.","engineCapabilities":["planning","tool-use","repo-context","patching","harness-checks"],"adapterBoundaries":["tools-spi","agent-orchestration","agent-shaker"],"policy":{"surfaceId":"coding-agent","memoryPreferred":true,"workspacePreferred":true,"harnessPreferred":true,"workflowPreferred":false,"suggestedSkills":["repo","tools","patching"],"requiredContextKeys":["surfaceId","workspace"],"routingHints":["inspect-workspace","plan-harness","prefer-tool-use"]},"profiles":[]},{"id":"assistant-agent","name":"Assistant Agent","role":"Task and conversation agent with memory, RAG, M